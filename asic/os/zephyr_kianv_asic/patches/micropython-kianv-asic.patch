--- a/ports/kianv_riscv/riscv.ld
+++ b/ports/kianv_riscv/riscv.ld
@@ -1,17 +1,56 @@
 MEMORY
 {
-  ram      (rwx) : ORIGIN = 0x00000000, LENGTH = (1024*1024*3)
+  FLASH (rx)  : ORIGIN = 0x020300000, LENGTH = 0x10000000
+  PSRAM (rwx) : ORIGIN = 0x080000000, LENGTH = 0x00800000
 }
-__stacktop = ORIGIN(ram) + LENGTH(ram);
 
-SECTIONS {
-	.memory : {
-		. = 0x000000;
-		*(.init);
-		*(.text);
-		*(*);
-		. = ALIGN(4);
-		end = .;
-	} >ram
+__stacktop = ORIGIN(PSRAM) + LENGTH(PSRAM);
+
+ENTRY(_start)
+
+SECTIONS
+{
+    .init : {
+        . = ALIGN(4);
+        build/start.o(.text*)
+    } >FLASH
+
+    .text : {
+        . = ALIGN(4);
+        _etext = .;
+        _sidata = _etext;
+    } >FLASH
+
+    .data : AT (_sidata) {
+        . = ALIGN(4);
+        _sdata = .;
+        _ram_start = .;
+        *(.text)
+        *(.text*)
+        . = ALIGN(4);
+        *(.data)
+        *(.data*)
+        *(.sdata)
+        *(.sdata*)
+        . = ALIGN(4);
+        *(.rodata)
+        *(.rodata*)
+        *(.srodata)
+        *(.srodata*)
+        . = ALIGN(4);
+        _edata = .;
+    } >PSRAM
+
+    .bss : {
+        . = ALIGN(4);
+        _sbss = .;
+        *(.bss)
+        *(.bss*)
+        *(.sbss)
+        *(.sbss*)
+        *(COMMON)
+        . = ALIGN(4);
+        _ebss = .;
+    } >PSRAM
+
+    .heap : {
+        . = ALIGN(4);
+        _heap_start = .;
+    } >PSRAM
 }
