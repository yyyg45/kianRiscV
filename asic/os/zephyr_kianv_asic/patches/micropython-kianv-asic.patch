diff --git a/ports/kianv_riscv/start.S b/ports/kianv_riscv/start.S
index 0b1c91e7c..8ea42410e 100644
--- a/ports/kianv_riscv/start.S
+++ b/ports/kianv_riscv/start.S
@@ -1,13 +1,62 @@
-.section .init
-.global main
+#define IO_BASE 0x10000000
+#define REG_DIV (IO_BASE + 0x0010)
+.equ FREQ, 30000000
+.equ BAUDRATE, 115200
 
-lui sp, %hi(__stacktop);
-addi sp, sp, %lo(__stacktop);
+.text
+.global _start
+.type _start, @function
 
-	/* call main */
-	call main
-  ebreak;
-loop:
-        j loop
-.balign 4
+_start:
+    addi x1, zero, 0
+    addi x2, zero, 0
+    addi x3, zero, 0
+    addi x4, zero, 0
+    addi x5, zero, 0
+    addi x6, zero, 0
+    addi x7, zero, 0
+    addi x8, zero, 0
+    addi x9, zero, 0
+    addi x10, zero, 0
+    addi x11, zero, 0
+    addi x12, zero, 0
+    addi x13, zero, 0
+    addi x14, zero, 0
+    addi x15, zero, 0
 
+    la t0, REG_DIV
+    li t1, ((FREQ / 10000) << 16) | (FREQ / BAUDRATE)
+    sw t1, 0(t0)
+
+    lui sp, %hi(__stacktop)
+    addi sp, sp, %lo(__stacktop)
+
+    la a0, _sbss
+    la a1, _ebss
+    bge a0, a1, end_init_bss
+loop_init_bss:
+    addi a0, a0, 4
+    sw zero, -4(a0)
+    blt a0, a1, loop_init_bss
+end_init_bss:
+
+    la a0, _sidata
+    la a1, _sdata
+    la a2, _edata
+    bge a1, a2, end_init_data
+loop_init_data:
+    lw a3, 0(a0)
+    addi a0, a0, 4
+    addi a1, a1, 4
+    sw a3, -4(a1)
+    blt a1, a2, loop_init_data
+end_init_data:
+
+    call main
+
+halt:
+    j halt
